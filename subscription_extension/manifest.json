{
  "manifest_version": 3,

  "name": "Subscription Guardian",

  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://subscription-tracker-api-s7b3.onrender.com/*"
  ]
}